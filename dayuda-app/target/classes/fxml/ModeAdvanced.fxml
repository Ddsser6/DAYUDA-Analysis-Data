<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="650.0" prefWidth="950.0" style="-fx-padding: 0; -fx-background-color: #0E1117;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dayuda.ModeAdvancedController">
   <children>
      
      <ImageView fitHeight="${scalingContainer.height}" fitWidth="${scalingContainer.width}" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@background_MenuUtama.jpg" />
         </image>
      </ImageView>
      <StackPane style="-fx-background-color: rgba(10, 12, 18, 0.82);" />

      <HBox fx:id="mainLayoutContainer">
         <children>
            
            <VBox minWidth="240.0" prefWidth="240.0" style="-fx-background-color: rgba(20, 24, 33, 0.7); -fx-padding: 25px; -fx-border-color: rgba(255, 255, 255, 0.05); -fx-border-width: 0 1px 0 0;">
               <children>
                  <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBack" text="← Back to Menu" 
                          style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0 0 20px 0; -fx-font-weight: bold;" />
                  
                  <Label text="Deep AI Mode" style="-fx-text-fill: #3B82F6; -fx-font-size: 18px; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-weight: bold;" />
                  <Label text="Fitur Lanjutan:" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-padding: 15px 0 5px 0;" />
                  
                  <Button alignment="BASELINE_LEFT" prefWidth="200.0" text="🤖 AI Chat Analytics" style="-fx-background-color: rgba(59, 130, 246, 0.15); -fx-text-fill: #3B82F6; -fx-background-radius: 4px; -fx-padding: 10px; -fx-font-weight: bold; -fx-border-color: rgba(59, 130, 246, 0.3); -fx-border-width: 1px;" />
               </children>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-padding: 25px;">
               <children>
                  
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label fx:id="lblTitle" text="🤖 Deep AI Analytics" style="-fx-text-fill: #FFFFFF; -fx-font-size: 26px; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-weight: bold;" />
                              <Label fx:id="lblSubtitle" text="Unggah file untuk berdiskusi langsung dengan kecerdasan buatan." style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0" style="-fx-background-color: rgba(59, 130, 246, 0.1); -fx-background-radius: 20px; -fx-padding: 6px 14px; -fx-border-color: rgba(59, 130, 246, 0.2); -fx-border-width: 1px;">
                           <children>
                              <Circle fill="#3B82F6" radius="3.5" style="-fx-effect: dropshadow(three-pass-box, #3B82F6, 6, 0, 0, 0);" />
                              <Label text="DEEP ENGINE" style="-fx-text-fill: #3B82F6; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        
                        <VBox fx:id="panelUpload" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.01); -fx-border-color: rgba(59, 130, 246, 0.2); -fx-border-style: dashed; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px;">
                           <children>
                              <Label style="-fx-font-size: 48px;" text="🧠" />
                              <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;" text="Hubungkan dataset untuk mengaktifkan AI Chat (.csv / .xlsx)" />
                              <Button fx:id="btnImport" mnemonicParsing="false" onAction="#handleImport" text="LAUNCH AI DISCOVERY" 
                                      style="-fx-background-color: #3B82F6; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12px 35px; -fx-background-radius: 6px; -fx-cursor: hand;" />
                           </children>
                        </VBox>

                        <VBox fx:id="panelData" spacing="15.0" visible="false">
                           <children>
                              
                              <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                                 <children>
                                    <Label fx:id="lblTableStatus" text="📋 Dataset Preview" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                    <TableView fx:id="tableJadwal" style="-fx-background-color: transparent; -fx-base: #151A23; -fx-control-inner-background: #0F131A;" VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>

                              <VBox prefHeight="230.0" maxHeight="250.0" spacing="10.0" style="-fx-background-color: rgba(20, 24, 33, 0.8); -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: rgba(255, 255, 255, 0.05); -fx-border-width: 1px;">
                                 <children>
                                    <Label text="💬 AI Chat Assistant" style="-fx-text-fill: #3B82F6; -fx-font-size: 13px; -fx-font-weight: bold;" />
                                    
                                    <TextArea fx:id="txtChatArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                              style="-fx-control-inner-background: #0A0D14; -fx-text-fill: #E5E7EB; -fx-font-family: 'Consolas', monospace; -fx-font-size: 12px; -fx-background-color: transparent; -fx-border-color: transparent;" />
                                    
                                    <HBox spacing="10.0" alignment="CENTER">
                                       <children>
                                          <TextField fx:id="txtChatInput" onAction="#handleSendMessage" promptText="Tanyakan sesuatu tentang data di atas kepada AI..." HBox.hgrow="ALWAYS" 
                                                     style="-fx-background-color: #0A0D14; -fx-text-fill: #FFFFFF; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 4px; -fx-padding: 8px;" />
                                          <Button fx:id="btnSend" mnemonicParsing="false" onAction="#handleSendMessage" text="TANYA AI" 
                                                  style="-fx-background-color: #3B82F6; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>

                           </children>
                        </VBox>

                     </children>
                  </StackPane>

               </children>
            </VBox>

         </children>
      </HBox>

      <StackPane fx:id="scalingContainer" mouseTransparent="true" visible="false" />

   </children>
</StackPane>
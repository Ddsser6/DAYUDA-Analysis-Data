<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="600.0" prefWidth="900.0" style="-fx-padding: 0; -fx-background-color: #0E1117;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dayuda.ModeStandarController">
   <children>
      
      <ImageView fitHeight="${scalingContainer.height}" fitWidth="${scalingContainer.width}" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@background_MenuUtama.jpg" />
         </image>
      </ImageView>
      <StackPane style="-fx-background-color: rgba(14, 17, 23, 0.75);" />

      <HBox fx:id="mainLayoutContainer">
         <children>
            
            <VBox minWidth="240.0" prefWidth="240.0" style="-fx-background-color: rgba(25, 30, 41, 0.65); -fx-padding: 25px; -fx-border-color: rgba(255, 255, 255, 0.05); -fx-border-width: 0 1px 0 0;">
               <children>
                  <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBack" text="← Back to Menu" 
                          style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0 0 20px 0; -fx-font-weight: bold;" />
                  
                  <Label text="Navigasi" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-weight: bold;" />
                  <Label text="Kontrol Dataset:" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-padding: 15px 0 5px 0;" />
                  
                  <Button alignment="BASELINE_LEFT" prefWidth="200.0" text="Overview Data" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: #FFFFFF; -fx-background-radius: 4px; -fx-padding: 10px; -fx-font-weight: bold;" />
               </children>
            </VBox>

            <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-padding: 30px;">
               <children>
                  
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label fx:id="lblTitle" text="📊 Data Analytics Dashboard" style="-fx-text-fill: #FFFFFF; -fx-font-size: 26px; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-weight: bold;" />
                              <Label fx:id="lblSubtitle" text="Silakan import dataset untuk memulai analisis." style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 20px; -fx-padding: 6px 14px;">
                           <children>
                              <Circle fill="#10B981" radius="3.5" style="-fx-effect: dropshadow(three-pass-box, #10B981, 6, 0, 0, 0);" />
                              <Label text="AI ACTIVE" style="-fx-text-fill: #10B981; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        
                        <VBox fx:id="panelUpload" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.02); -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-style: dashed; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px;">
                           <children>
                              <Label style="-fx-font-size: 48px;" text="📁" />
                              <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;" text="Silakan masukkan file dataset terlebih dahulu (.csv/.xlsx)" />
                              <Button fx:id="btnImport" mnemonicParsing="false" onAction="#handleImport" text="IMPORT DATASET" 
                                      style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12px 35px; -fx-background-radius: 6px; -fx-cursor: hand;" />
                           </children>
                        </VBox>

                        <VBox fx:id="panelData" spacing="15.0" visible="false">
                           <children>
                              <Label fx:id="lblTableStatus" text="Active Dataset View" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;" />
                              
                              <TableView fx:id="tableJadwal" style="-fx-background-color: transparent; -fx-base: #1E2530; -fx-control-inner-background: #151B26;" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>

                     </children>
                  </StackPane>

               </children>
            </VBox>

         </children>
      </HBox>

      <StackPane fx:id="scalingContainer" mouseTransparent="true" visible="false" />

   </children>
</StackPane>